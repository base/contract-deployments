# Old CB L1 multisig (issuer; current owner via its L2 alias).
OWNER_SAFE=0x5dfEB066334B67355A15dc9b67317fD2a2e1f77f

# New CB L1 multisig (new owner). The script derives its L2 alias via applyL1ToL2Alias.
