# Required: Git commit hash for https://github.com/base/contracts
BASE_CONTRACTS_COMMIT=be7c7a642e430fa64b04b63203839f8c81f48466

# Network-specific addresses are automatically loaded from {network}/.env via include ../.env

# ==============================================================================
# DeployFeeDisburser.s.sol
# ==============================================================================

# Minimum time in seconds between fee disbursements (must be >= 86400 / 24 hours)
# 604800 = 7 days
FEE_DISBURSEMENT_INTERVAL=604800

# ==============================================================================
# UpgradeFeeDisburser.s.sol
# ==============================================================================

# L1 Safe that owns the FeeDisburser proxy (old CB nested safe)
OWNER_SAFE=0x5dfEB066334B67355A15dc9b67317fD2a2e1f77f

# OptimismPortal2 contract address on L1
OPTIMISM_PORTAL_ADDR=0x49f53e41452C74589E85cA1677426Ba426459e85

# FeeDisburser proxy contract address on L2
FEE_DISBURSER_ADDR=0x76355A67fCBCDE6F9a69409A8EAd5EaA9D8d875d

# New FeeDisburser implementation address on L2 (set after running deploy-fee-disburser)
FEE_DISBURSER_IMPL_ADDR=0x3A9F58cC41f29F9e16A8497D2F158B7E8c67e78b

# ==============================================================================
# Multisig Operations
# ==============================================================================

# Required for the task signer tool
RECORD_STATE_DIFF=true
