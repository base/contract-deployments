# Required: Git commit hash for https://github.com/base/contracts
BASE_CONTRACTS_COMMIT=e8fe64dcd6c4f96b5aa2ab7ef6b444b060e3c02d

# Network-specific addresses are automatically loaded from {network}/.env via include ../.env

# Required: Current gas limit on chain (for validation)
FROM_GAS_LIMIT=400000000

# Required: New gas limit to set
TO_GAS_LIMIT=1200000000

# Required: Current EIP-1559 elasticity on chain (for validation)
FROM_ELASTICITY=5

# Required: New EIP-1559 elasticity to set
TO_ELASTICITY=15

# Required: Current EIP-1559 denominator on chain (for validation)
FROM_DENOMINATOR=100

# Required: New EIP-1559 denominator to set
TO_DENOMINATOR=100

# Required: Current DA footprint gas scalar on chain (for validation)
FROM_DA_FOOTPRINT_GAS_SCALAR=148

# Required: New DA footprint gas scalar to set
# The DA footprint scalar controls both:
# - a soft cap, where DA footprint begins increasing the EIP-1559 base fee
# - a hard cap, where DA footprint prevents further block inclusion
#
# soft cap = (gas_limit / elasticity) / scalar
# hard cap = gas_limit / scalar
#
# With the current parameters (gas_limit=1.2B, elasticity=15, scalar=446):
# - soft cap: ~180 KB per L2 block (~5.6 blobs per L1 block)
# - hard cap: ~2.7 MB per L2 block (~84 blobs per L1 block)
#
# This preserves the current ~2.7 MB per-L2-block hard cap. The soft cap
# and sustained blob targeting may be revisited in a follow-up.
TO_DA_FOOTPRINT_GAS_SCALAR=446

# Optional: New SystemConfig implementation address (from prerequisite MAX_GAS_LIMIT upgrade).
# When set, the simulation overrides the proxy's EIP-1967 implementation slot so that
# setGasLimit can exceed the old MAX_GAS_LIMIT before the upgrade is executed on-chain.
SYSTEM_CONFIG_IMPL=0x4ABA707Dc42c49586158037EC7F2e1E48254c735

# Required: Address of a signer on OWNER_SAFE (used for simulation)
SENDER=0x6e427c3212C0b63BE0C382F97715D49b011bFF33

# Enable state diff recording for validation
RECORD_STATE_DIFF=true
