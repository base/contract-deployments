BASE_CONTRACTS_COMMIT=1baa168c9db6a946ae47863ea07295bedb3599a6

# Multiproof configuration.
# The scripts use DISPUTE_GAME_FACTORY_PROXY + GAME_TYPE as the source of truth
# to recover the live AggregateVerifier and its current immutables.
GAME_TYPE=621

# New SP1 gateway configuration.
# SP1_VERIFIER_ROUTE is the current SP1 Groth16 v6.1.0 verifier implementation
# routed by the current Succinct gateway for selector 0x4388a21c.
SP1_VERIFIER_ROUTE=0xb69f2584CBcFf99a58C4e7002E8b89Af54a6f4e2

# Re-exported for task simulation UI (signer-tool invokes forge directly and does not
# pick up variables coming from the Makefile's `-include ../.env`).
PROXY_ADMIN_OWNER=0x0fe884546476dDd290eC46318785046ef68a0BA9
ANCHOR_STATE_REGISTRY_PROXY=0x2fF5cC82dBf333Ea30D8ee462178ab1707315355
DISPUTE_GAME_FACTORY_PROXY=0xd6E6dBf4F7EA0ac412fD8b65ED297e64BB7a06E1

# Validation generation
RECORD_STATE_DIFF=true
