# Required: Git commit hash for https://github.com/base/contracts
# Pinned to the v8.2.0 release tag. It carries the reinitializer(3) BalanceTracker (introduced in
# #253 / CHAIN-3814, relocated to src/L1 in #269). The proxy is at initialized version 2 onchain,
# so an older reinitializer(2) implementation would revert on initialize.
BASE_CONTRACTS_COMMIT=e225648a7ed538e7e28c041d44f3b7a606ba7743

# ==============================================================================
# Multisig configuration
# ==============================================================================

# The CB Incident multisig — admin (proxy owner) of the BalanceTracker proxy.
OWNER_SAFE=0x14536667Cd30e52C0b458BaACcB9faDA7046E056

# A current signer on OWNER_SAFE, used for simulation / validation generation.
# Must match the sender defined in validations/base-signer.json
SENDER=0x1841CB3C2ce6870D0417844C817849da64E6e937

# Enable state diff recording for the task signer tool
RECORD_STATE_DIFF=true

# ==============================================================================
# Network addresses (mirror of mainnet/.env)
#
# These are re-declared here on purpose: the task signer tool invokes forge directly and only
# loads this task's .env (foundry dotenv), not the parent mainnet/.env. The deploy step still
# works from either source, but the multisig script (run by the signer tool) needs them here.
# ==============================================================================
BALANCE_TRACKER=0x23B597f33f6f2621F77DA117523Dffd634cDf4ea
BATCH_SENDER=0x5050f69a9786f081509234f1a7f4684b5e5b76c9
PROPOSER=0xc1366Fabe614d42D367A1ecE61821238A1d31cF5
CHALLENGER=0x819501cdA743a606A93dbEF254FE0D263Ce7d102
REGISTRAR=0xd87488Dbb5b6F47cc6c15Dd95Bb60c83D3031b04

# ==============================================================================
# Target balances (in wei) the BalanceTracker tops each system address up to.
# ==============================================================================
BATCH_SENDER_TARGET_BALANCE=550000000000000000000
PROPOSER_TARGET_BALANCE=25000000000000000000
CHALLENGER_TARGET_BALANCE=5000000000000000000
REGISTRAR_TARGET_BALANCE=5000000000000000000
