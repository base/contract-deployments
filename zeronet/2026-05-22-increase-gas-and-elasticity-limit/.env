# Required: Git commit hash for https://github.com/base/contracts
BASE_CONTRACTS_COMMIT=1baa168c9db6a946ae47863ea07295bedb3599a6

# Network-specific addresses are automatically loaded from {network}/.env via include ../.env

# Required: Current gas limit on chain (for validation)
#
# NOTE on Zeronet "FROM_*" values: the L1 SystemConfig storage for the
# EIP-1559 params and the DA footprint gas scalar has never been written
# (slot 0x6a == 0x0...0). The chain therefore operates with the rollup-
# config defaults (denominator=250, elasticity=6, daFootprintGasScalar=400)
# which surface in the L2 block extraData and on the L1Block predeploy.
#
# The script's pre-checks in _buildCalls read directly from the raw
# SystemConfig getters, so FROM_ELASTICITY, FROM_DENOMINATOR, and
# FROM_DA_FOOTPRINT_GAS_SCALAR are all set to 0 to match the on-chain
# storage. Only FROM_GAS_LIMIT is non-zero because SystemConfig.gasLimit
# has been explicitly set (to 25M).
FROM_GAS_LIMIT=25000000

# Required: New gas limit to set
TO_GAS_LIMIT=1200000000

# Required: Current EIP-1559 elasticity on chain (raw SystemConfig storage)
FROM_ELASTICITY=0

# Required: New EIP-1559 elasticity to set
TO_ELASTICITY=15

# Required: Current EIP-1559 denominator on chain (raw SystemConfig storage)
FROM_DENOMINATOR=0

# Required: New EIP-1559 denominator to set
TO_DENOMINATOR=100

# Required: Current DA footprint gas scalar on chain (raw SystemConfig storage)
FROM_DA_FOOTPRINT_GAS_SCALAR=0

# Required: New DA footprint gas scalar to set.
#
# Computed via the `make da-scalar TARGET_BLOB_COUNT=21` helper:
#
#   da_footprint_gas_scalar = TO_GAS_LIMIT / (TO_ELASTICITY * TARGET_BLOB_COUNT * 32000)
#                           = 1,200,000,000 / (15 * 21 * 32,000)
#                           = 119
#
# The DA footprint scalar controls both:
#   - a soft cap, where DA footprint begins increasing the EIP-1559 base fee
#   - a hard cap, where DA footprint prevents further block inclusion
#
#     soft cap = (gas_limit / elasticity) / scalar
#     hard cap = gas_limit / scalar
#
# With the new parameters (gas_limit=1.2B, elasticity=15, scalar=119):
#   - soft cap: ~672 KB per L2 block (~21 blobs per L1 block target)
#   - hard cap: ~10.1 MB per L2 block
TO_DA_FOOTPRINT_GAS_SCALAR=119

# Required: Address of a signer on OWNER_SAFE (used for simulation).
# This must be an owner of the INCIDENT_MULTISIG (0x856611ed7e07d83243b15e93f6321f2df6865852),
# which is itself an owner of PROXY_ADMIN_OWNER (0x3d59999977e0896ee1f8783bb8251df16fb483e9).
SENDER=0x6e427c3212C0b63BE0C382F97715D49b011bFF33

# Rollback target values. On Zeronet the raw SystemConfig storage for
# EIP-1559 params and DA footprint scalar was never written (all zeros).
# setEIP1559Params enforces denominator >= 1 and elasticity >= 1, so the
# rollback cannot restore literal zeros. Instead we target the rollup-config
# defaults the chain actually operates with. NOTE: this is a one-time solution
# because the current onchain values are zeros, we cannot rollback to zero due to
# the EIP-1559 denominator >= 1 constraint.
ROLLBACK_GAS_LIMIT=25000000
ROLLBACK_ELASTICITY=6
ROLLBACK_DENOMINATOR=250
ROLLBACK_DA_FOOTPRINT_GAS_SCALAR=400

# Enable state diff recording for validation
RECORD_STATE_DIFF=true
