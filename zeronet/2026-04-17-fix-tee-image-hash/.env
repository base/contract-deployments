BASE_CONTRACTS_COMMIT=ddd5a09e4752707637648ab8d89ef2d2e479ac13

# AggregateVerifier redeployment.
# Deployment params are read on-chain from EXISTING_AGGREGATE_VERIFIER at script setUp time,
# with only TEE_IMAGE_HASH overridden to the correct value.
EXISTING_AGGREGATE_VERIFIER=0x016CdB236F103078677AEA6d9287eA9B2f33c872

# Safety check: the deploy script asserts that the existing TEE_IMAGE_HASH matches this prestate.
CURRENT_TEE_IMAGE_HASH=0xbcf94c238e15b5e423050df2b6f354ab2c5f3af791d8f862f654a195af9f491e

# Target TEE image hash baked into the new AggregateVerifier.
TEE_IMAGE_HASH=0x11fb64617dfa2875d31b0cfb656666fd8cee65eb134fefeca171b9b6b4444a64

# Re-exported for task simulation UI (signer-tool invokes forge directly and does not
# pick up variables coming from the Makefile's `-include ../.env`).
PROXY_ADMIN_OWNER=0x3d59999977e0896ee1f8783bb8251df16fb483e9
DISPUTE_GAME_FACTORY_PROXY=0x154972ab98a5e321a9c7ab7677973f1f501a8090

# Validation generation
RECORD_STATE_DIFF=true
