BASE_CONTRACTS_COMMIT=1baa168c9db6a946ae47863ea07295bedb3599a6

# Multiproof configuration.
# The scripts use DISPUTE_GAME_FACTORY_PROXY + GAME_TYPE as the source of truth
# to recover the live AggregateVerifier and its current immutables.
GAME_TYPE=621

# Verifier deployment inputs. Mirrors mainnet target hashes from
# mainnet/2026-05-27-update-aggregate-verifier (so testnets exercise the same
# TEE image + ZK range program ahead of mainnet rollout). ZK_AGGREGATE_HASH is
# unchanged from the prior testnet deployment but is set explicitly for clarity.
TEE_IMAGE_HASH=0xc9536fb5b1387f30d16f6b95a5a26de352f8056866482bca632f7219896ea74c
ZK_RANGE_HASH=0x44f625fa2a41367670d74a7b0d9899412dc1ca406f90df7a5bd9f8ae581ee47f
ZK_AGGREGATE_HASH=0x003147cde8e7d519d3dbae6b76f1198a70d4ff477a3aaea73bee4153f250288a

# Anchor reset inputs. STARTING_ANCHOR_ROOT is `optimism_outputAtBlock`
# at STARTING_ANCHOR_L2_BLOCK_NUMBER on the zeronet op-node proofs RPC
# (https://base-zeronet-reth-proofs-donotuse.cbhq.net:7545). The
# AnchorStateRegistry will be re-initialised against this anchor so the
# new AggregateVerifier starts from a fresh, recent root rather than
# the stale anchor seeded at the previous deployment.
STARTING_ANCHOR_L2_BLOCK_NUMBER=3020400
STARTING_ANCHOR_ROOT=0xcc7faffb8f23e867ebe781797d4b73f2b7f189cdbd937edefae937e0f1eb5e50

# Re-exported for task simulation UI (signer-tool invokes forge directly and does not
# pick up variables coming from the Makefile's `-include ../.env`).
PROXY_ADMIN_OWNER=0x3d59999977e0896ee1f8783bb8251df16fb483e9
L1_PROXY_ADMIN=0x44f00318360258744a0daa957c2d15080a473469
SYSTEM_CONFIG=0xcc7c76564bea74a963a0bd75e0bc9bce3ff0ea80
ANCHOR_STATE_REGISTRY_PROXY=0x60a6c389f0bc5ce4269a40d9695927bc58700328
DISPUTE_GAME_FACTORY_PROXY=0x154972ab98a5e321a9c7ab7677973f1f501a8090

# Validation generation
RECORD_STATE_DIFF=true
